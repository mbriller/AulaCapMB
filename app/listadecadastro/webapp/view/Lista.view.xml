<mvc:View
    controllerName="listadecadastro.controller.Lista"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page
        id="page"
        title="{i18n>title}"
        class="sapUiContentPadding">
        <Input
            id='label'
            value='{oModelLista>/variavelInput}'
            liveChange="onDigitando"/>

        <List
            headerText="Cadastro"
            headerLevel="H2"
            items="{oModelLista>/Lista}">
            <StandardListItem
                title="{oModelLista>ID} - {oModelLista>name}"
                counter=""/>
        </List>
    </Page>
</mvc:View>
